# ---- Server ----
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
REQUEST_BODY_LIMIT_MB=10

# ---- Mode / feature toggles ----
# MODE=full     : everything (default) — sync + async + storage + queue + redis
# MODE=minimal  : sync /v1/convert only — no Redis, no storage, no queue, no auth
# Individual ENABLE_* flags override MODE-derived defaults when set.
MODE=full
# ENABLE_QUEUE=true
# ENABLE_STORAGE=true
# ENABLE_RATE_LIMIT=true
AUTH_REQUIRED=true

# ---- Redis / Queue ----
REDIS_URL=redis://localhost:6379
QUEUE_NAME=html-to-pdf
QUEUE_CONCURRENCY=4

# ---- Browser / Renderer ----
BROWSER_POOL_SIZE=4
BROWSER_IDLE_TTL_MS=60000
RENDER_TIMEOUT_MS=30000
NAVIGATION_TIMEOUT_MS=20000
MAX_CONTENT_BYTES=26214400   # 25 MiB
MAX_HTML_BYTES=10485760       # 10 MiB
MAX_PAGES_PER_DOC=500

# ---- Security ----
API_KEYS=dev-key-change-me
ALLOWED_URL_HOSTS=            # comma-separated; empty = any (public only, SSRF-guarded)
BLOCKED_URL_HOSTS=metadata.google.internal,169.254.169.254
ALLOW_PRIVATE_NETWORKS=false

# ---- Storage ----
STORAGE_DRIVER=local          # local | s3
LOCAL_STORAGE_DIR=./storage
SIGNED_URL_TTL_SECONDS=3600
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ---- Rate limits ----
RATE_LIMIT_PER_MIN=60
