{
  "name": "@saad5400/html-to-pdf",
  "version": "0.1.0",
  "description": "Production-grade HTML/URL to PDF conversion service and CLI — Fastify + Playwright + BullMQ",
  "type": "module",
  "license": "MIT",
  "author": "Saad5400 <saad@sb.sa>",
  "homepage": "https://github.com/Saad5400/html-to-pdf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saad5400/html-to-pdf.git"
  },
  "bugs": {
    "url": "https://github.com/Saad5400/html-to-pdf/issues"
  },
  "keywords": [
    "html",
    "pdf",
    "html-to-pdf",
    "url-to-pdf",
    "playwright",
    "chromium",
    "fastify",
    "bullmq",
    "pdf-cli",
    "render",
    "headless"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "htp": "dist/cli/htp.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker/index.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "minimal": "MODE=minimal AUTH_REQUIRED=false tsx src/server.ts",
    "cli": "tsx src/cli/htp.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "openapi": "tsx scripts/emit-openapi.ts > openapi.yaml",
    "loadtest": "tsx scripts/loadtest.ts",
    "visual": "tsx scripts/visual-render.ts",
    "local": "bash scripts/local.sh",
    "prepare": "playwright install --with-deps chromium || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.654.0",
    "@aws-sdk/s3-request-presigner": "^3.654.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.20.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.47.2",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
